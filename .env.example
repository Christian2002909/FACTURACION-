# ═══════════════════════════════════════════════════════════════════════════
# SISTEMA DE FACTURACIÓN PARAGUAY — Configuración (.env)
# Copiar a .env y completar con valores reales
# ═══════════════════════════════════════════════════════════════════════════

# ─── AUTENTICACIÓN JWT ─────────────────────────────────────────────────────
# Usuario y contraseña por defecto (cambiar en producción)
APP_USERNAME=admin
APP_PASSWORD_HASH=$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36WQoeG6Lruj3vjPGga31lW

# Clave secreta para firmar tokens JWT (CAMBIAR EN PRODUCCIÓN)
# Generar: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── BASE DE DATOS ─────────────────────────────────────────────────────────
# SQLite (desarrollo) o PostgreSQL/MySQL (producción)
DATABASE_URL=sqlite:///./data/facturacion.db
# DATABASE_URL=postgresql://usuario:contraseña@localhost/facturacion_py

# ─── PDF ───────────────────────────────────────────────────────────────────
# Directorio donde se guardan PDFs generados
PDF_OUTPUT_DIR=data/facturas

# ─── SIFEN (Factura Electrónica) ───────────────────────────────────────────
# Documentación oficial DNIT:
# https://www.dnit.gov.py/web/e-kuatia/documentacion
# Guía de pruebas:
# https://www.dnit.gov.py/documents/20123/424160/Guia+de+Pruebas+para+e-kuatia.pdf

# Habilitar facturación electrónica (requiere microservicio Node.js SIFEN)
SIFEN_ENABLED=false

# Ambiente: "test" para pruebas, "prod" para producción
SIFEN_AMBIENTE=test

# Ruta al certificado digital PKCS#12 (proporcionado por DNIT)
# IMPORTANTE: Nunca commitear este archivo a git
SIFEN_CERT_PATH=data/certificados/cert.p12

# Contraseña del certificado digital
SIFEN_CERT_PASSWORD=

# Tipo de contribuyente: 1=Persona Física, 2=Persona Jurídica
SIFEN_CONTRIBUYENTE_TIPO=1

# ─── NOTAS ────────────────────────────────────────────────────────────────
# - Cambiar JWT_SECRET_KEY en producción
# - Si SIFEN_ENABLED=true, asegurarse que microservicio Node.js está corriendo
# - data/certificados/ debe estar en .gitignore (archivos sensibles)
# - data/facturas/ contiene PDFs generados (puede crecer mucho)
